# ── Server ────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — do not set it manually in Railway
PORT=7070

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add a Postgres plugin
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret
JWT_TTL_HOURS=24
MAGIC_LINK_TTL_MIN=15

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your@gmail.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# Must match the URI you added in Google Cloud Console
GOOGLE_REDIRECT_URL=https://your-frontend-domain.com/auth/google/callback

# ── Push Notifications (optional) ────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=your@gmail.com
